# URL of your IBM Maximo instance
MAXIMO_URL=https://your-maximo-url.com

# Maximo REST API Key
API_KEY=your_secret_api_key_here

# Server port (optional, defaults to 3030)
PORT=3030

# ---------------------------------------------------------------------------
# Authentication Provider
# Options:
#   static   - validate incoming requests against a static MCP_API_KEY (default)
#   entra-id - validate incoming requests using MS Entra ID (Azure AD) JWT tokens
# ---------------------------------------------------------------------------
AUTH_PROVIDER=static

# ---------------------------------------------------------------------------
# Static API Key Auth (used when AUTH_PROVIDER=static)
# Clients must send: Authorization: Bearer <value>
# ---------------------------------------------------------------------------
MCP_API_KEY=your-highly-secure-mcp-token-here

# ---------------------------------------------------------------------------
# MS Entra ID OAuth 2.0 Auth (used when AUTH_PROVIDER=entra-id)
#
# Prerequisites (Azure Portal):
#   1. Register the MCP Server as an App in Entra ID (App registrations)
#   2. Under "Expose an API", set an Application ID URI (e.g. api://<client-id>)
#      and add a scope (e.g. mcp.access)
#   3. Configure client apps to request a token for this audience
#
# AZURE_TENANT_ID  : Your MS Entra ID directory (tenant) ID
# AZURE_CLIENT_ID  : The application (client) ID of the MCP Server's app registration
# AZURE_AUDIENCE   : Expected 'aud' claim in the token.
#                    Defaults to api://<AZURE_CLIENT_ID> if not set.
# ---------------------------------------------------------------------------
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_AUDIENCE=api://xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx  # optional override
